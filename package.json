{
  "name": "alouette",
  "description": "AI Translation & Text-to-Speech Tool - Cross-platform application built with Tauri, Vue 3, and Rust for high-quality multilingual translation and intelligent speech synthesis using Ollama AI servers.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:android": "scripts/ensure-android-config.sh && tauri android build",
    "build:ios": "tauri ios build",
    "dev:android": "scripts/ensure-android-config.sh && tauri android dev",
    "dev:ios": "tauri ios dev",
    "vite:build": "vite build",
    "tauri": "tauri",
    "android:init": "tauri android init && scripts/ensure-android-config.sh",
    "android:config": "scripts/ensure-android-config.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "vue": "^3.5",
    "vue-router": "^4.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5",
    "vite": "^6.3.5"
  },
  "keywords": [
    "translation",
    "text-to-speech",
    "tts",
    "ai",
    "ollama",
    "multilingual",
    "tauri",
    "vue3",
    "rust",
    "cross-platform"
  ],
  "author": "Alouette Team",
  "license": "MIT"
}
